EMAIL_FROM="CET Exam Portal <your_email@gmail.com>"

# Razorpay Configuration
RAZORPAY_KEY_ID=paste_my_key_id_here
RAZORPAY_SECRET=paste_my_key_secret_here
RAZORPAY_WEBHOOK_SECRET=paste_my_webhook_secret_here
