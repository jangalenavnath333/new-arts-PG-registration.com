<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Apply for CET Exam | CET Portal</title>
  <meta name="description" content="Submit your application for the CET online entrance exam. Fill in your details and upload required documents." />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../css/main.css" />

  <style>
    /* ──────────────────────────────────────────────────────────────────────── */
    /* Receipt Card ─────────────────────────────────────────────────────────── */
    #printReceiptWrapper { display: none; }
    .receipt-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:9999;
      display:flex; align-items:flex-start; justify-content:center; overflow-y:auto; padding:20px 0; }
    .receipt-card { background:linear-gradient(160deg,#0f172a,#1e1b4b); border:1px solid rgba(99,102,241,0.4);
      border-radius:20px; width:min(860px,95vw); padding:0; overflow:hidden; box-shadow:0 24px 80px rgba(0,0,0,0.6); }
    .receipt-header { background:linear-gradient(135deg,#312e81,#4c1d95); padding:28px 32px; text-align:center; }
    .receipt-body { padding:28px 32px; }
    .receipt-section { margin-bottom:24px; }
    .receipt-section-title { font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase;
      color:#818cf8; margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid rgba(99,102,241,0.2); }
    .receipt-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(200px,1fr)); gap:14px; }
    .receipt-field { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08);
      border-radius:10px; padding:12px 14px; }
    .receipt-field-label { font-size:10px; color:#6b7280; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px; }
    .receipt-field-value { font-size:14px; font-weight:600; color:#f1f5f9; font-family:'Space Grotesk',sans-serif; }
    .receipt-track { background:linear-gradient(135deg,rgba(16,185,129,0.15),rgba(5,150,105,0.1));
      border:2px solid rgba(16,185,129,0.4); border-radius:16px; padding:20px; text-align:center; margin-bottom:24px; }
    .receipt-actions { display:flex; gap:12px; padding:20px 32px 28px; flex-wrap:wrap; justify-content:center; }

    .btn-login-go { background:transparent; color:#818cf8; border:1.5px solid #6366f1;
      padding:14px 28px; border-radius:12px; font-size:14px; font-weight:600; cursor:pointer;
      text-decoration:none; display:flex; align-items:center; gap:8px; transition:background 0.2s; }
    .btn-login-go:hover { background:rgba(99,102,241,0.15); }
    .pay-badge { display:inline-flex; align-items:center; gap:6px; background:rgba(245,158,11,0.15);
      border:1px solid rgba(245,158,11,0.4); border-radius:20px; padding:4px 14px;
      font-size:12px; font-weight:600; color:#fcd34d; }

    /* --- Form Layout Fixes --- */
    .form-card.wide {
      max-width: 900px !important;
    }
    .steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      width: 100%;
      margin-bottom: 30px;
    }
    .step {
      text-align: center;
      padding: 14px 10px;
      border: 1px solid rgba(255,255,255,0.12);
      font-size: 13px;
      font-weight: 500;
      color: var(--mid);
      cursor: pointer;
      background: transparent;
    }
    .step.active {
      font-weight: 600;
      color: var(--primary-light);
      background: rgba(99,102,241,0.1);
      border-color: rgba(99,102,241,0.3);
    }
    .form-step {
      display: none;
    }
    .form-step.active {
      display: block;
    }
    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
    }
    .full-width {
      grid-column: 1 / -1;
    }
    .form-actions {
      display: flex;
      justify-content: space-between;
      margin-top: 30px;
    }
  </style>
</head>
<body>
  <div class="bg-particles"></div>

  <!-- Top bar -->
  <nav class="navbar">
    <div class="nav-container">
      <a href="../index.html" class="nav-brand-banner" style="text-decoration:none; display: block; border-radius: 8px; overflow: hidden; background: #ffffff; padding: 4px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
        <img src="../images/logo.png" alt="New Arts, Commerce and Science College, Department of Computer Science" style="height: 56px; display: block;" />
      </a>
      <div class="nav-links">
        <a href="login.html" class="nav-btn btn-outline">Already Applied? Login</a>
      </div>
    </div>
  </nav>

  <div class="form-page" style="padding-top: 100px;">
    <div class="form-card wide">
      <!-- Header -->
      <div class="form-logo">
        <span>📝 Student Application Form</span>
        <p>Fill all fields carefully. All information must be accurate.</p>
      </div>

      <!-- Progress Steps -->      <div class="steps">
        <div class="step active" id="stepTab1" onclick="window.showStep(1)">
          1. Personal Info
        </div>
        <div class="step" id="stepTab2" onclick="if(validateStep(1)) window.showStep(2)">
          2. Academic Details
        </div>
        <div class="step" id="stepTab3" onclick="if(validateStep(1) && validateStep(2)) window.showStep(3)">
          3. Documents & Payment
        </div>
      </div>
      <div id="alertBox"></div>

      <form id="applyForm" novalidate>
        <!-- Step 1: Personal Info -->
        <div class="form-step active" id="step1">
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label" for="fullName">Full Name <span>*</span></label>
              <input type="text" id="fullName" class="form-input" placeholder="Enter your full name" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="email">Email Address <span>*</span></label>
              <input type="email" id="email" class="form-input" placeholder="your@email.com" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="mobileNumber">Mobile Number <span>*</span></label>
              <input type="tel" id="mobileNumber" class="form-input" placeholder="10-digit mobile number" maxlength="10" required autofocus />
            </div>
            <div class="form-group">
              <label class="form-label" for="dob">Date of Birth <span>*</span></label>
              <input type="date" id="dob" class="form-input" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="addressLine1">Address Line 1 <span>*</span></label>
              <input type="text" id="addressLine1" class="form-input" placeholder="House No, Street Name" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="addressLine2">Address Line 2</label>
              <input type="text" id="addressLine2" class="form-input" placeholder="Landmark, Area (optional)" />
            </div>
            <div class="form-group">
              <label class="form-label" for="village">Village / City <span>*</span></label>
              <input type="text" id="village" class="form-input" placeholder="Enter village or city" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="taluka">Taluka <span>*</span></label>
              <input type="text" id="taluka" class="form-input" placeholder="Enter taluka" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="district">District <span>*</span></label>
              <input type="text" id="district" class="form-input" placeholder="Enter district" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="state">State <span>*</span></label>
              <input type="text" id="state" class="form-input" placeholder="Enter state" value="Maharashtra" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="pinCode">PIN Code <span>*</span></label>
              <input type="text" id="pinCode" class="form-input" placeholder="6-digit PIN code" maxlength="6" required />
            </div>
          </div>
          <div class="form-actions" style="justify-content: flex-end;">
            <button type="button" class="btn btn-solid btn-lg" onclick="nextStep(1)">Continue &rarr;</button>
          </div>
        </div>

        <!-- Step 2: Academic Details -->
        <div class="form-step" id="step2">
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label" for="twelfthPercent">12th Percentage <span>*</span></label>
              <input type="number" id="twelfthPercent" class="form-input" placeholder="e.g. 85.5" min="0" max="100" step="0.1" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="board">Board / University <span>*</span></label>
              <input type="text" id="board" class="form-input" placeholder="e.g. CBSE, ICSE, State Board" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="yearOfPassing">Year of Passing <span>*</span></label>
              <select id="yearOfPassing" class="form-select" required>
                <option value="">Select Year</option>
                <option>2026</option><option>2025</option><option>2024</option>
                <option>2023</option><option>2022</option><option>2021</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="stream">Stream <span>*</span></label>
              <select id="stream" class="form-select" required onchange="updateCoursesForStream()">
                <option value="">Select Stream</option>
                <option>Science (PCM)</option>
                <option>Science (PCB)</option>
                <option>Commerce</option>
                <option>Arts / Humanities</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="tenthPercent">10th Percentage <span>*</span></label>
              <input type="number" id="tenthPercent" class="form-input" placeholder="e.g. 78.2" min="0" max="100" step="0.1" required />
            </div>
            
            <div class="form-group">
              <label class="form-label" for="casteCategory">Caste Category <span>*</span></label>
              <select id="casteCategory" class="form-select" onchange="handleCasteChange()" required>
                <option value="">Select Category</option>
                <option value="Open / General">Open / General</option>
                <option value="OBC">OBC</option>
                <option value="SBC">SBC</option>
                <option value="EWS">EWS</option>
                <option value="SEBC">SEBC</option>
                <option value="VJ">VJ</option>
                <option value="NT-A">NT-A</option>
                <option value="NT-B">NT-B</option>
                <option value="NT-C">NT-C</option>
                <option value="NT-D">NT-D</option>
                <option value="SC">SC</option>
                <option value="ST">ST</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="form-group">
                <label class="form-label" for="mathsMarks">12th Maths Marks <span>*</span></label>
                <input type="number" id="mathsMarks" class="form-input" placeholder="Enter Maths marks" min="0" max="100" required />
            </div>
            <div class="form-group full-width">
                <label class="form-label" for="courseApplied">Course Applied For <span>*</span></label>
                <select id="courseApplied" class="form-select" required>
                  <option value="">-- Select Stream First --</option>
                </select>
                <div id="artsWarning" style="display:none; margin-top:10px; padding:12px 16px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.4); border-radius:10px;">
                  <p style="color:#f87171; font-weight:700; font-size:13px; margin:0;">🚫 Arts students are not eligible to apply for this CET.</p>
                  <p style="color:#fca5a5; font-size:12px; margin:4px 0 0;">Please contact the college office for further information.</p>
                </div>
            </div>
          </div>
          <div class="form-actions">
            <button type="button" class="btn btn-outline-sm btn-lg" onclick="prevStep(1)">&larr; Back</button>
            <button type="button" class="btn btn-solid btn-lg" onclick="nextStep(2)">Continue &rarr;</button>
          </div>
        </div>
        <!-- Step 3: Documents & Payment -->
        <div class="form-step" id="step3">
          <!-- 10th Marksheet Upload -->
          <div class="form-grid" style="margin-bottom:20px;">
            <div class="form-group">
                <label class="form-label">Upload 10th Marksheet <span>*</span></label>
                <div class="upload-area" id="tenthUpload">
                  <input type="file" id="tenthFile" accept="image/*,.pdf" onchange="handleFileUpload('tenthFile','tenthPreview','tenthName')" />
                  <div class="upload-icon">📄</div>
                  <div class="upload-text">Upload 10th Marksheet<br><strong>JPG, PNG, PDF</strong> • Max 5MB</div>
                  <div id="tenthPreview" class="upload-preview"></div>
                </div>
                <p id="tenthName" style="font-size:12px; color:var(--success); margin-top:4px;"></p>
            </div>
            <div class="form-group">
              <label class="form-label">Upload 12th Marksheet <span>*</span></label>
              <div class="upload-area" id="twelfthUpload">
                <input type="file" id="twelfthFile" accept="image/*,.pdf" onchange="handleFileUpload('twelfthFile','twelfthPreview','twelfthName')" />
                <div class="upload-icon">📄</div>
                <div class="upload-text">Upload 12th Marksheet<br><strong>JPG, PNG, PDF</strong> • Max 5MB</div>
                <div id="twelfthPreview" class="upload-preview"></div>
              </div>
              <p id="twelfthName" style="font-size:12px; color:var(--success); margin-top:4px;"></p>
            </div>
          </div>

          <!-- Passport Photo -->
          <div class="form-group mb-6">
            <label class="form-label">Passport Photo <span>*</span></label>
            <div class="upload-area" id="photoUpload">
                <input type="file" id="photoFile" accept="image/*" onchange="handleFileUpload('photoFile','photoPreview','photoName')" />
                <div class="upload-icon">📸</div>
                <div class="upload-text">Click to upload photo<br><strong>JPG, PNG</strong> • Max 2MB</div>
                <div id="photoPreview" class="upload-preview"></div>
            </div>
            <p id="photoName" style="font-size:12px; color:var(--success); margin-top:4px;"></p>
          </div>

          <!-- Signature Upload -->
          <div class="form-grid" style="margin-bottom:20px;">
            <div class="form-group">
              <label class="form-label">Signature Upload <span>*</span></label>
              <div class="upload-area" id="signatureUpload">
                <input type="file" id="signatureFile" accept="image/*" onchange="handleFileUpload('signatureFile','signaturePreview','signatureName')" />
                <div class="upload-icon">✍️</div>
                <div class="upload-text">Upload Signature<br><strong>JPG, PNG</strong> • Max 2MB</div>
                <div id="signaturePreview" class="upload-preview"></div>
              </div>
              <p id="signatureName" style="font-size:12px; color:var(--success); margin-top:4px;"></p>
            </div>
          </div>

          <!-- Dynamic caste-based documents -->
          <div id="dynamicDocContainer" class="form-grid">
             <!-- Dynamically injected document fields will appear here -->
          </div>

          <div style="background:rgba(245,158,11,0.1); border:1px solid rgba(245,158,11,0.3); border-radius:12px; padding:16px; margin:16px 0;">
            <p style="font-size:13px; color:#fcd34d; margin-bottom:8px;"><strong>⚠ Important Information:</strong></p>
            <ul style="font-size:13px; color:var(--light); padding-left:16px;">
              <li>Your mobile number will be your login password</li>
              <li>Application status will be updated within 2-3 business days</li>
              <li>You will receive your Student ID upon approval</li>
              <li>Exam schedule will be shared after approval</li>
            </ul>
          </div>

          <div class="form-group">
            <label style="display:flex; align-items:flex-start; gap:10px; cursor:pointer;">
              <input type="checkbox" id="termsCheck" style="margin-top:3px; accent-color:var(--primary);" />
              <span style="font-size:13px; color:var(--light);">I confirm that all information provided is accurate and I agree to the <a href="#" style="color:var(--primary-light);">terms and conditions</a>.</span>
            </label>
          </div>

          <!-- Payment Section -->
          <div style="background:rgba(99,102,241,0.05); border:1px solid var(--card-border); border-radius:16px; padding:28px; margin:20px 0;">
            <!-- Payment Header -->
            <div style="text-align:center; margin-bottom:24px;">
              <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);border-radius:24px;padding:6px 16px;margin-bottom:12px;">
                <span style="font-size:12px;font-weight:700;color:#34d399;letter-spacing:1px;">DEMO PAYMENT</span>
              </div>
              <p style="font-size:22px; font-weight:800; color:#fff; margin:0 0 4px;">Application Fee: <span style="color:#34d399;">₹1</span></p>
              <p style="font-size:13px; color:var(--mid); margin:0;">Scan QR with any UPI app — PhonePe, GPay, Paytm</p>
            </div>

            <div style="display:flex; gap:28px; align-items:flex-start; flex-wrap:wrap; justify-content:center;">
              <!-- QR + UPI Info -->
              <div style="text-align:center; min-width:200px;">
                <div style="background:#fff; padding:12px; border-radius:12px; display:inline-block; margin-bottom:12px; box-shadow:0 4px 20px rgba(0,0,0,0.3);">
                  <!-- Using existing QR image; replace with college QR later -->
                  <img src="../images/upi_qr.png" alt="UPI Payment QR" id="paymentQrImg"
                    style="width:180px; height:180px; object-fit:contain; display:block;"
                    onerror="this.src='https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=upi://pay?pa=9730011724@pthdfc&pn=Master+Navnath+Babasaheb+Jangale&am=1&cu=INR'" />
                </div>
                <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:12px 16px;text-align:left;">
                  <p style="font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin:0 0 2px;">UPI ID</p>
                  <p style="font-size:14px;font-weight:700;color:#e2e8f0;margin:0 0 8px;font-family:monospace;">9730011724@pthdfc</p>
                  <p style="font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin:0 0 2px;">Payee Name</p>
                  <p style="font-size:13px;font-weight:600;color:#c4b5fd;margin:0 0 8px;">Master Navnath Babasaheb Jangale</p>
                  <p style="font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin:0 0 2px;">Amount</p>
                  <p style="font-size:16px;font-weight:800;color:#34d399;margin:0;">₹1.00</p>
                </div>
                <!-- Countdown Timer -->
                <div style="margin-top:12px;background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.3);border-radius:10px;padding:10px;text-align:center;">
                  <p style="font-size:10px;color:#fcd34d;margin:0 0 4px;font-weight:600;text-transform:uppercase;letter-spacing:1px;">Session expires in</p>
                  <p id="paymentCountdown" style="font-size:24px;font-weight:800;color:#f59e0b;margin:0;font-family:monospace;">10:00</p>
                </div>
              </div>

              <!-- Payment Form -->
              <div style="flex:1; min-width:280px; max-width:380px;">
                <div style="margin-bottom:16px;">
                  <label class="form-label" for="transactionId">Transaction ID / UTR Number <span>*</span></label>
                  <input type="text" id="transactionId" class="form-input"
                    placeholder="Enter UTR / Transaction ID (min 8 chars)"
                    minlength="8" required
                    style="font-family:monospace; letter-spacing:1px;" />
                  <p style="font-size:11px;color:#64748b;margin:4px 0 0;">Find UTR in your UPI app under payment history</p>
                </div>

                <div style="margin-bottom:16px;">
                  <label class="form-label">Payment Screenshot <span>*</span></label>
                  <input type="file" id="paymentScreenshot" class="form-input" accept="image/*"
                    onchange="handleFileUpload('paymentScreenshot','paymentPreview','paymentName')" required />
                  <p id="paymentName" style="font-size:11px; color:var(--success); margin-top:4px;"></p>
                  <div id="paymentPreview" class="upload-preview" style="display:none; height:80px; margin-top:5px;"></div>
                </div>

                <div style="margin-bottom:20px;">
                  <label style="display:flex; align-items:flex-start; gap:10px; cursor:pointer;">
                    <input type="checkbox" id="finalTermsCheck" style="margin-top:3px; accent-color:var(--primary);" />
                    <span style="font-size:13px; color:var(--light);">I confirm payment of ₹1 is successful and the UTR entered is correct.</span>
                  </label>
                </div>

                <!-- Payment Status Banner (hidden initially) -->
                <div id="paymentStatusBanner" style="display:none; padding:16px; border-radius:12px; text-align:center; margin-bottom:16px;"></div>
              </div>
            </div>

            <div style="margin-top:8px; padding:12px 16px; background:rgba(245,158,11,0.08); border:1px solid rgba(245,158,11,0.2); border-radius:10px;">
              <p style="font-size:11px;color:#fcd34d;margin:0;">⚠ <strong>Demo Mode:</strong> Payment is auto-verified instantly. No real money is deducted beyond ₹1 test amount.</p>
            </div>
          </div>

          <div class="form-actions">
            <button type="button" class="btn btn-outline-sm btn-lg" onclick="prevStep(2)">&larr; Back</button>
            <button type="submit" class="btn btn-solid btn-lg" id="submitBtn">
              💳 Submit Payment & Apply
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <div id="receiptOverlay" class="receipt-overlay" style="display:none;">
    <div class="receipt-card" id="printReceiptWrapper">

      <!-- Header -->
      <div class="receipt-header">
        <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:10px;">
          <img src="../images/logo.png" alt="NACS Logo" style="height:52px;border-radius:8px;background:#fff;padding:3px;" />
        </div>
        <p style="font-size:11px;letter-spacing:2px;color:#a5b4fc;text-transform:uppercase;margin-bottom:4px;">Ahmednagar Jilha Maratha Vidya Prasarak Samaj</p>
        <h2 style="font-size:18px;font-weight:800;color:#fff;margin:0 0 2px;">New Arts, Commerce and Science College</h2>
        <p style="font-size:12px;color:#c4b5fd;margin:0;">Department of Computer Science — CET Online Exam Portal</p>
        <div style="margin-top:14px;display:inline-block;background:rgba(255,255,255,0.12);border-radius:8px;padding:5px 16px;">
          <span style="font-size:12px;font-weight:700;color:#fff;letter-spacing:1px;">APPLICATION RECEIPT / ADMIT ACKNOWLEDGEMENT</span>
        </div>
      </div>

      <!-- Body -->
      <div class="receipt-body">

        <!-- Track ID Banner -->
        <div class="receipt-track">
          <p style="font-size:11px;color:#6ee7b7;letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;">✅ Application Submitted Successfully</p>
          <p style="font-size:11px;color:#9ca3af;margin-bottom:10px;">Your Application / Track ID</p>
          <p id="appIdDisplay" style="font-size:28px;font-weight:800;font-family:'Space Grotesk',sans-serif;color:#34d399;letter-spacing:3px;"></p>
          <p style="font-size:11px;color:#9ca3af;margin-top:8px;">Save this ID to track your application status</p>
        </div>

        <!-- Personal Information -->
        <div class="receipt-section">
          <p class="receipt-section-title">Personal Information</p>
          <div style="display:flex; gap:24px; align-items:flex-start;">
            <div class="receipt-grid" style="flex:1;">
              <div class="receipt-field"><div class="receipt-field-label">Full Name</div><div class="receipt-field-value" id="rc_name">—</div></div>
              <div class="receipt-field"><div class="receipt-field-label">Email Address</div><div class="receipt-field-value" id="rc_email" style="font-size:12px;">—</div></div>
              <div class="receipt-field"><div class="receipt-field-label">Mobile Number</div><div class="receipt-field-value" id="rc_mobile">—</div></div>
              <div class="receipt-field"><div class="receipt-field-label">Date of Birth</div><div class="receipt-field-value" id="rc_dob">—</div></div>
              <div class="receipt-field" style="grid-column:1/-1;"><div class="receipt-field-label">Address</div><div class="receipt-field-value" id="rc_address" style="font-size:13px;">—</div></div>
            </div>
            <!-- Photo on Receipt -->
            <div style="width:120px; text-align:center;">
              <div style="width:120px; height:150px; background:rgba(255,255,255,0.05); border:1.5px solid rgba(255,255,255,0.1); border-radius:8px; overflow:hidden; display:flex; align-items:center; justify-content:center; margin-bottom:8px;">
                <img id="rc_photo" src="" alt="Photo" style="width:100%; height:100%; object-fit:cover; display:none;" />
                <span id="rc_photo_placeholder" style="color:var(--mid); font-size:10px;">PHOTO</span>
              </div>
              <p style="font-size:9px; color:var(--mid); text-transform:uppercase; letter-spacing:1px;">Passport Photo</p>
            </div>
          </div>
        </div>

        <!-- Academic Details -->
        <div class="receipt-section">
          <p class="receipt-section-title">Academic Details</p>
          <div class="receipt-grid">
            <div class="receipt-field"><div class="receipt-field-label">10th Percentage</div><div class="receipt-field-value" id="rc_tenth">—</div></div>
            <div class="receipt-field"><div class="receipt-field-label">12th Percentage</div><div class="receipt-field-value" id="rc_twelfth">—</div></div>
            <div class="receipt-field"><div class="receipt-field-label">12th Maths Marks</div><div class="receipt-field-value" id="rc_maths">—</div></div>
            <div class="receipt-field"><div class="receipt-field-label">Board / University</div><div class="receipt-field-value" id="rc_board">—</div></div>
            <div class="receipt-field"><div class="receipt-field-label">Year of Passing</div><div class="receipt-field-value" id="rc_year">—</div></div>
            <div class="receipt-field"><div class="receipt-field-label">Stream</div><div class="receipt-field-value" id="rc_stream">—</div></div>
            <div class="receipt-field"><div class="receipt-field-label">Caste Category</div><div class="receipt-field-value" id="rc_caste">—</div></div>
            <div class="receipt-field" style="grid-column:1/-1;"><div class="receipt-field-label">Course Applied For</div><div class="receipt-field-value" id="rc_course">—</div></div>
          </div>
        </div>

        <!-- Submission Info -->
        <div class="receipt-section">
          <p class="receipt-section-title">Submission Information</p>
          <div class="receipt-grid">
            <div class="receipt-field"><div class="receipt-field-label">Submitted On</div><div class="receipt-field-value" id="rc_date">—</div></div>
            <div class="receipt-field"><div class="receipt-field-label">Exam Year</div><div class="receipt-field-value">2026 – 2027</div></div>
          </div>
        </div>

        <!-- Important Notes -->
        <div style="background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.25);border-radius:12px;padding:14px 18px;margin-bottom:8px;">
          <p style="font-size:11px;font-weight:700;color:#fcd34d;margin-bottom:8px;">⚠ Important Instructions</p>
          <ul style="font-size:11px;color:#d1d5db;padding-left:16px;margin:0;line-height:1.8;">
            <li>Your mobile number is your login password for the student portal.</li>
            <li>Payment verification may take 10–30 minutes during business hours.</li>
            <li>Application status will be updated within 2–3 business days after payment confirmation.</li>
            <li>Admit card / Exam schedule will be shared via email after approval.</li>
            <li>Keep this receipt and your Transaction ID for future reference.</li>
          </ul>
        </div>

        <p style="font-size:10px;color:#4b5563;text-align:center;margin-top:12px;">This is a computer-generated application receipt. No physical signature required.</p>
      </div>

      <!-- ——— Action Buttons ——— -->
      <div class="receipt-actions">
        <a href="login.html" class="btn-login-go">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
          Track Application &rarr;
        </a>
      </div>
      <div style="text-align:center; margin-top:24px; padding-bottom:40px;">
        <p style="font-size:11px; color:#4b5563;">
          Having trouble? <a href="#" onclick="localStorage.clear(); location.reload();" style="color:var(--primary-light); text-decoration:none;">Reset Portal Data</a> (Clears all local storage)
        </p>
      </div>
    </div>
  </div>

  <script type="module">
    import DB from '../js/db.js';

    window.currentStep = 1; 
    let fileDataMap = {}; 

    const casteDocumentMap = {
      "Open / General": ["Domicile Certificate", "ID Proof"],
      "OBC": ["Caste Certificate", "Domicile Certificate", "Non-Creamy Layer Certificate", "ID Proof"],
      "SBC": ["Caste Certificate", "Domicile Certificate", "Non-Creamy Layer Certificate", "ID Proof"],
      "EWS": ["EWS Certificate", "Domicile Certificate", "ID Proof"],
      "SEBC": ["Caste Certificate", "Domicile Certificate", "Non-Creamy Layer Certificate", "ID Proof"],
      "VJ": ["Caste Certificate", "Domicile Certificate", "Non-Creamy Layer Certificate", "ID Proof"],
      "NT-A": ["Caste Certificate", "Domicile Certificate", "Non-Creamy Layer Certificate", "ID Proof"],
      "NT-B": ["Caste Certificate", "Domicile Certificate", "Non-Creamy Layer Certificate", "ID Proof"],
      "NT-C": ["Caste Certificate", "Domicile Certificate", "Non-Creamy Layer Certificate", "ID Proof"],
      "NT-D": ["Caste Certificate", "Domicile Certificate", "Non-Creamy Layer Certificate", "ID Proof"],
      "SC": ["Caste Certificate", "Domicile Certificate", "ID Proof"],
      "ST": ["Caste Certificate", "Domicile Certificate", "ID Proof"],
      "Other": ["Domicile Certificate", "ID Proof"]
    };

    window.handleCasteChange = function() {
      const caste = document.getElementById('casteCategory').value;
      const container = document.getElementById('dynamicDocContainer');
      container.innerHTML = '';
      
      if (!caste) return;

      const docs = casteDocumentMap[caste] || [];
      docs.forEach(docName => {
        const docId = docName.replace(/\s+/g, '');
        const col = document.createElement('div');
        col.className = 'form-group';
        col.innerHTML = `
          <label class="form-label">${docName} <span>*</span></label>
          <div class="upload-area" id="${docId}Upload">
            <input type="file" id="${docId}File" accept="image/*,.pdf" onchange="handleFileUpload('${docId}File','${docId}Preview','${docId}Name')" />
            <div class="upload-icon">${docName.includes('Marksheet') ? '📄' : docName.includes('ID') ? '🪪' : '📜'}</div>
            <div class="upload-text">Upload ${docName}<br><strong>JPG, PNG, PDF</strong> • Max 5MB</div>
            <div id="${docId}Preview" class="upload-preview"></div>
          </div>
          <p id="${docId}Name" style="font-size:12px; color:var(--success); margin-top:4px;"></p>
        `;
        container.appendChild(col);
      });
    }

    window.showAlert = function(msg, type) {
      document.getElementById('alertBox').innerHTML = `
        <div class="alert alert-${type}">${msg}</div>
      `;
      window.scrollTo({ top: 0, behavior: 'smooth' });
      setTimeout(() => { document.getElementById('alertBox').innerHTML = ''; }, 4000);
    }

    window.handleFileUpload = function(inputId, previewId, nameId) {
      const file = document.getElementById(inputId).files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (e) => {
        const previewEl = document.getElementById(previewId);
        if (file.type.startsWith('image/')) {
          if(previewEl) {
            previewEl.innerHTML = `<img src="${e.target.result}" alt="Preview" />`;
            previewEl.style.display = 'block';
          }
          
          const img = new Image();
          img.onload = function() {
            const canvas = document.createElement('canvas');
            const MAX_WIDTH = 600;
            const MAX_HEIGHT = 600;
            let width = img.width;
            let height = img.height;
            if (width > height) {
              if (width > MAX_WIDTH) { height *= MAX_WIDTH / width; width = MAX_WIDTH; }
            } else {
              if (height > MAX_HEIGHT) { width *= MAX_HEIGHT / height; height = MAX_HEIGHT; }
            }
            canvas.width = width; canvas.height = height;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, width, height);
            const dataUrl = canvas.toDataURL('image/jpeg', 0.2); 
            
            fileDataMap[inputId] = dataUrl;
          }
          img.src = e.target.result;
        } else {
          fileDataMap[inputId] = e.target.result;
          if(previewEl) previewEl.style.display = 'block';
        }
        document.getElementById(nameId).textContent = '✅ ' + file.name;
      };
      reader.readAsDataURL(file);
    }

    window.nextStep = function(step) {
      if (validateStep(step)) showStep(step + 1);
    }

    window.prevStep = function(step) {
      showStep(step - 1);
    }

    window.showStep = function(step) {
      document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
      const stepEl = document.getElementById('step' + step);
      if (stepEl) {
        stepEl.classList.add('active');
      }
      
      document.querySelectorAll('.step').forEach((t, i) => {
        if (i + 1 === step) {
          t.classList.add('active');
        } else {
          t.classList.remove('active');
        }
      });

      window.currentStep = step;
      window.scrollTo({ top: 0, behavior: 'smooth' });

      const url = new URL(window.location);
      url.searchParams.set('step', step);
      window.history.replaceState({}, '', url);
    }

    window.validateStep = function(step) {
      document.getElementById('alertBox').innerHTML = ''; 
      
      if (step === 1) {
        const name = document.getElementById('fullName').value.trim();
        const email = document.getElementById('email').value.trim();
        const mobile = document.getElementById('mobileNumber').value.trim();
        const dob = document.getElementById('dob').value.trim();
        const addr1 = document.getElementById('addressLine1').value.trim();
        const villageCity = document.getElementById('village').value.trim();
        const talukaVal = document.getElementById('taluka').value.trim();
        const districtVal = document.getElementById('district').value.trim();
        const stateVal = document.getElementById('state').value.trim();
        const pinVal = document.getElementById('pinCode').value.trim();

        if (!name || !email || !mobile || !dob || !addr1 || !villageCity || !talukaVal || !districtVal || !stateVal || !pinVal) { 
          showAlert('⚠ Please fill all required fields.', 'warning'); 
          return false; 
        }
        if (!/^\S+@\S+\.\S+$/.test(email)) { 
          showAlert('⚠ Please enter a valid email.', 'warning'); 
          return false; 
        }
        if (!/^\d{10}$/.test(mobile)) { 
          showAlert('⚠ Mobile number must be 10 digits.', 'warning'); 
          return false; 
        }
        if (!/^\d{6}$/.test(pinVal)) {
          showAlert('⚠ PIN Code must be 6 digits.', 'warning');
          return false;
        }
      }
      if (step === 2) {
        const tenthPct = document.getElementById('tenthPercent').value;
        const twelfthPct = document.getElementById('twelfthPercent').value;
        const board = document.getElementById('board').value.trim();
        const year = document.getElementById('yearOfPassing').value;
        const stream = document.getElementById('stream').value;
        const course = document.getElementById('courseApplied').value;
        const caste = document.getElementById('casteCategory').value;
        const mathsEl = document.getElementById('mathsMarks');
        const maths = mathsEl ? mathsEl.value : '';

        if (!tenthPct) { 
          showAlert('⚠ Please provide 10th percentage.', 'warning'); 
          return false; 
        }
        if (stream === 'Arts / Humanities') {
          showAlert('🚫 Arts / Humanities students are not eligible to apply for this CET.', 'warning');
          return false;
        }
        if (!course) {
          showAlert('⚠ Please select a Course Applied For.', 'warning');
          return false;
        }
        if (!twelfthPct || !board || !year || !stream || !caste || !maths) { 
          showAlert('⚠ Please fill all required fields.', 'warning'); 
          return false; 
        }
        
        if (parseFloat(tenthPct) < 0 || parseFloat(tenthPct) > 100) { showAlert('⚠ Please enter valid 10th percentage.', 'warning'); return false; }
        if (parseFloat(twelfthPct) < 0 || parseFloat(twelfthPct) > 100) { showAlert('⚠ Please enter valid 12th percentage.', 'warning'); return false; }
        if (parseFloat(maths) < 0 || parseFloat(maths) > 100) { showAlert('⚠ Please enter valid Maths marks.', 'warning'); return false; }
      }
      if (step === 3) {
        if (!fileDataMap['tenthFile']) { 
          showAlert('⚠ Please upload your 10th Marksheet.', 'warning'); 
          return false; 
        }
        if (!fileDataMap['twelfthFile']) { 
          showAlert('⚠ Please upload your 12th Marksheet.', 'warning'); 
          return false; 
        }
        if (!fileDataMap['signatureFile']) { 
          showAlert('⚠ Please upload your signature.', 'warning'); 
          return false; 
        }
        if (!fileDataMap['photoFile']) { 
          showAlert('⚠ Please upload your passport photo.', 'warning'); 
          return false; 
        }
        if (!document.getElementById('termsCheck').checked) {
          showAlert('⚠ Please agree to terms and conditions.', 'warning');
          return false;
        }


        const caste = document.getElementById('casteCategory').value;
        const requiredDocs = casteDocumentMap[caste] || [];
        
        for (const docName of requiredDocs) {
          const docId = docName.replace(/\s+/g, '') + 'File';
          if (!fileDataMap[docId]) {
              showAlert(`⚠ Please upload required document: ${docName}`, 'warning');
              return false;
          }
        }
      }
      return true;
    }

    document.getElementById('applyForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const btn = document.getElementById('submitBtn');
      const banner = document.getElementById('paymentStatusBanner');

      const fail = (step, msg) => {
        showStep(step);
        showAlert(msg, 'warning');
        const oldHtml = btn.innerHTML;
        btn.innerHTML = '⚠ Check missing fields above';
        btn.style.background = '#ef4444';
        setTimeout(() => { btn.innerHTML = oldHtml; btn.style.background = ''; }, 3000);
      };

      if (!validateStep(1)) { fail(1, '⚠ Please complete Personal Information.'); return; }
      if (!validateStep(2)) { fail(2, '⚠ Please complete Academic Details.'); return; }
      if (!validateStep(3)) { fail(3, '⚠ Please complete Documents step.'); return; }

      // Payment validation
      const txnId = document.getElementById('transactionId').value.trim();
      if (!txnId || txnId.length < 8) {
        fail(3, '⚠ Please enter a valid UTR / Transaction ID (minimum 8 characters).');
        return;
      }
      if (!fileDataMap['paymentScreenshot']) {
        fail(3, '⚠ Please upload your payment screenshot.');
        return;
      }
      if (!document.getElementById('finalTermsCheck').checked) {
        fail(3, '⚠ Please check the confirmation box before submitting.');
        return;
      }

      // DEMO PAYMENT ONLY. Real auto verification requires payment gateway webhook.
      // Show "Verifying payment..." state
      btn.disabled = true;
      btn.innerHTML = '⌛ Verifying payment...';
      if (banner) {
        banner.style.display = 'block';
        banner.style.cssText = 'display:block;padding:16px;border-radius:12px;text-align:center;margin-bottom:16px;background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.3);';
        banner.innerHTML = '<p style="color:#fcd34d;font-weight:700;font-size:14px;margin:0;">⌛ Verifying payment...</p><p style="color:#94a3b8;font-size:12px;margin:4px 0 0;">Please wait while we confirm your payment.</p>';
      }

      // Simulate 2s payment gateway delay
      setTimeout(() => {
        if (banner) {
          banner.style.cssText = 'display:block;padding:16px;border-radius:12px;text-align:center;margin-bottom:16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);';
          banner.innerHTML = '<p style="color:#34d399;font-weight:800;font-size:16px;margin:0;">✅ Payment Successful!</p><p style="color:#6ee7b7;font-size:13px;margin:4px 0 0;">Application Submitted Successfully</p>';
        }
        btn.innerHTML = '✅ Finalizing Application...';
        setTimeout(() => { proceedWithSubmission(); }, 800);
      }, 2000);
    });

    function proceedWithSubmission() {
      const btn = document.getElementById('submitBtn');
      try {
        // DEMO PAYMENT ONLY. Real auto verification requires payment gateway webhook.
        const generatedStudentId = 'CET2026' + String(Math.floor(Math.random() * 9000) + 1000);
        const appId = 'APP' + Date.now();
        const paymentDate = new Date().toISOString();
        const now = paymentDate;

        const caste = document.getElementById('casteCategory').value;
        const course = document.getElementById('courseApplied').value;
        const stream = document.getElementById('stream').value;
        const utrNumber = document.getElementById('transactionId').value.trim();
        const paymentProofName = (document.getElementById('paymentName').textContent || '').replace('\u2705 ', '') || 'Payment_Screenshot.jpg';

        // Collect uploaded doc names
        const uploadedDocs = [];
        if (fileDataMap['photoFile'])  uploadedDocs.push('Passport Photo');
        if (fileDataMap['tenthFile'])  uploadedDocs.push('10th Marksheet');
        if (fileDataMap['twelfthFile'])  uploadedDocs.push('12th Marksheet');
        if (fileDataMap['signatureFile'])  uploadedDocs.push('Signature');
        const requiredDocs = casteDocumentMap[caste] || [];
        for (const docName of requiredDocs) {
          const docId = docName.replace(/\s+/g, '') + 'File';
          if (fileDataMap[docId]) uploadedDocs.push(docName);
        }

        // Canonical application object shared across all stores
        const applicationData = {
          applicationId:  appId,
          studentId:      generatedStudentId,
          fullName:  document.getElementById('fullName').value.trim(),
          name:      document.getElementById('fullName').value.trim(),
          email:     document.getElementById('email').value.trim().toLowerCase(),
          mobile:    document.getElementById('mobileNumber').value.trim(),
          dob:       document.getElementById('dob').value.trim(),
          address:   [
            document.getElementById('addressLine1').value.trim(),
            document.getElementById('addressLine2').value.trim(),
            document.getElementById('village').value.trim(),
            'Taluka: ' + document.getElementById('taluka').value.trim(),
            'District: ' + document.getElementById('district').value.trim(),
            document.getElementById('state').value.trim(),
            'PIN: ' + document.getElementById('pinCode').value.trim()
          ].filter(Boolean).join(', '),
          courseApplied: course,
          stream:        stream,
          category:      caste,
          academicDetails: {
            tenthPercent:   document.getElementById('tenthPercent').value,
            twelfthPercent: document.getElementById('twelfthPercent').value,
            board:          document.getElementById('board').value.trim(),
            yearOfPassing:  document.getElementById('yearOfPassing').value,
            stream:         stream,
            mathsMarks:     document.getElementById('mathsMarks').value,
            courseApplied:  course,
            casteCategory:  caste
          },
          uploadedDocuments:     uploadedDocs,
          uploadedFiles:         fileDataMap,
          paymentScreenshotData: fileDataMap['paymentScreenshot'] || null,
          transactionId:  utrNumber,
          paymentUtr:     utrNumber,
          paymentProof:   paymentProofName,
          paymentStatus:  'PAID_DEMO',
          paymentAmount:  'Rs.1',
          paymentDate:    paymentDate,
          applicationStatus: 'PENDING_APPROVAL',  // Admin must approve manually
          status:            'pending',
          examStatus:        'NOT_SCHEDULED',
          hasAttempted:      false,
          submittedAt: now,
          appliedAt:   now,
          password:    document.getElementById('mobileNumber').value.trim(),
        };

        // Strip heavy files to save localStorage space across ALL stores except the main DB
        let lightApp = { ...applicationData };
        delete lightApp.uploadedFiles;
        delete lightApp.paymentScreenshotData;

        // 1. Save to DB (cet_students) for student login (needs full data for admin preview)
        const student = DB.addStudent(applicationData);
        DB.updateStudent(student.id, {
          status:            'pending',
          studentId:         generatedStudentId,
          paymentStatus:     'PAID_DEMO',
          paymentUtr:        utrNumber,
          paymentDate:       paymentDate,
          applicationStatus: 'PENDING_APPROVAL',
          courseApplied:     course,
          category:          caste,
        });

        // 2. Append to cetApplications (Admin -> Applications tab)
        let cetApps = [];
        try { cetApps = JSON.parse(localStorage.getItem('cetApplications')) || []; } catch(e) {}
        cetApps = cetApps.filter(a => a.email !== applicationData.email);
        
        cetApps.push(lightApp);
        localStorage.setItem('cetApplications', JSON.stringify(cetApps));

        // 3. cetApprovedStudents is populated ONLY when Admin clicks Approve (not here)
        // 4. Append to cetPayments (Admin -> Payment Verification tab)
        let payments = [];
        try { payments = JSON.parse(localStorage.getItem('cetPayments')) || []; } catch(e) {}
        payments = payments.filter(p => p.email !== applicationData.email);
        payments.push({
          applicationId: appId, studentId: generatedStudentId,
          fullName: applicationData.fullName, email: applicationData.email,
          courseApplied: course, paymentStatus: 'PAID_DEMO', paymentAmount: 'Rs.1',
          paymentUtr: utrNumber, paymentDate: paymentDate,
          // Omitting heavy screenshot here to save space; admin will fetch from DB
          submittedAt: now,
        });
        localStorage.setItem('cetPayments', JSON.stringify(payments));

        // 5. Keep cetApplication (singular) for receipt.html
        // We only need the photo for the receipt
        let receiptApp = { ...lightApp };
        receiptApp.uploadedFiles = { photoFile: fileDataMap['photoFile'] };
        localStorage.setItem('cetApplication', JSON.stringify(receiptApp));

        window.location.href = 'receipt.html';

      } catch (e) {
        btn.disabled = false;
        btn.innerHTML = 'Submit Payment & Apply';
        console.error(e);
        window.proceedWithSubmission = proceedWithSubmission;
        if (e.message && (e.message.includes('quota') || e.message.includes('storage'))) {
          showAlert('Storage Full! Your images or PDFs are too large.<br><br><button onclick="localStorage.removeItem(\'cet_students\'); localStorage.removeItem(\'cetApplications\'); localStorage.removeItem(\'cetPayments\'); Object.keys(fileDataMap).forEach(k => { if(k !== \'photoFile\') fileDataMap[k] = \'data:application/pdf;base64,\'; }); window.proceedWithSubmission();" style="background:#ef4444; color:white; border:none; padding:8px 16px; border-radius:8px; cursor:pointer; font-weight:bold; margin-top:8px;">Clear Old Data & Submit Now!</button>', 'danger');
        } else {
          showAlert('System Error: ' + (e.message || 'Unknown error'), 'danger');
        }
      } finally {
        setTimeout(() => {
          if (btn.disabled) { btn.disabled = false; btn.innerHTML = 'Submit Payment & Apply'; }
        }, 10000);
      }
    }


    window.saveReceiptAsPDF = function() {
      const appId = document.getElementById('appIdDisplay').textContent || 'CET_Receipt';
      const prevTitle = document.title;
      document.title = 'CET_Application_' + appId;
      window.print();
      document.title = prevTitle;
    }

    window.printReceipt = function() {
      window.print();
    }

    // ── Stream → Course Dependency Logic ─────────────────────
    const STREAM_COURSES = {
      'Science (PCM)': [
        'BSc Computer Science',
        'BSc Data Science',
        'BCA (Bachelor of Computer Applications)'
      ],
      'Science (PCB)': [
        'Cloud Computing'
      ],
      'Commerce': [
        'BCA (Bachelor of Computer Applications)'
      ],
      'Arts / Humanities': []
    };

    window.updateCoursesForStream = function() {
      const streamEl = document.getElementById('stream');
      const courseEl = document.getElementById('courseApplied');
      const artsWarn = document.getElementById('artsWarning');
      const continueBtn = document.querySelector('#step2 .btn-solid');

      const selectedStream = streamEl.value;
      console.log('Selected stream:', selectedStream);

      // Reset course dropdown
      courseEl.innerHTML = '';
      courseEl.disabled = false;

      if (!selectedStream) {
        courseEl.innerHTML = '<option value="">-- Select Stream First --</option>';
        artsWarn.style.display = 'none';
        if (continueBtn) { continueBtn.disabled = false; continueBtn.style.opacity = '1'; }
        return;
      }

      if (selectedStream === 'Arts / Humanities') {
        courseEl.innerHTML = '<option value="">No course available for this stream</option>';
        courseEl.disabled = true;
        artsWarn.style.display = 'block';
        if (continueBtn) { continueBtn.disabled = true; continueBtn.style.opacity = '0.4'; }
        console.log('Available courses: []');
        return;
      }

      artsWarn.style.display = 'none';
      if (continueBtn) { continueBtn.disabled = false; continueBtn.style.opacity = '1'; }

      const filteredCourses = STREAM_COURSES[selectedStream] || [];
      console.log('Available courses:', filteredCourses);

      courseEl.innerHTML = '<option value="">Select Course</option>';
      filteredCourses.forEach(course => {
        const opt = document.createElement('option');
        opt.textContent = course;
        opt.value = course;
        courseEl.appendChild(opt);
      });
    };

    // ── 10-Minute Payment Countdown Timer ───────────────────
    let countdownInterval = null;
    function startPaymentCountdown() {
      let seconds = 10 * 60; // 10 minutes
      const el = document.getElementById('paymentCountdown');
      if (!el) return;
      clearInterval(countdownInterval);
      countdownInterval = setInterval(() => {
        if (seconds <= 0) {
          clearInterval(countdownInterval);
          if (el) el.textContent = 'EXPIRED';
          if (el) el.style.color = '#ef4444';
          return;
        }
        seconds--;
        const m = String(Math.floor(seconds / 60)).padStart(2, '0');
        const s = String(seconds % 60).padStart(2, '0');
        if (el) el.textContent = `${m}:${s}`;
        if (seconds <= 60) { if (el) el.style.color = '#ef4444'; }
      }, 1000);
    }

    // ── Initialization ──────────────────────────────────────
    window.addEventListener('DOMContentLoaded', () => {
      const params = new URLSearchParams(window.location.search);
      const stepParam = parseInt(params.get('step'));
      if (stepParam && stepParam >= 1 && stepParam <= 3) {
        window.showStep(stepParam);
        if (stepParam === 3) startPaymentCountdown();
      }
    });

    // Start timer when user reaches Step 4
    const _origShowStep = window.showStep;
    window.showStep = function(step) {
      _origShowStep(step);
      if (step === 3) startPaymentCountdown();
    };
  </script>
</body>
</html>
